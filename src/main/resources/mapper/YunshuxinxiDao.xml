<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.YunshuxinxiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.YunshuxinxiEntity" id="yunshuxinxiMap">
        <result property="yunshucheci" column="yunshucheci"/>
        <result property="weixianpinbianhao" column="weixianpinbianhao"/>
        <result property="weixianpinmingcheng" column="weixianpinmingcheng"/>
        <result property="shuliang" column="shuliang"/>
        <result property="qidian" column="qidian"/>
        <result property="zhongdian" column="zhongdian"/>
        <result property="zhuangtai" column="zhuangtai"/>
        <result property="yunshulujing" column="yunshulujing"/>
        <result property="zhanghao" column="zhanghao"/>
        <result property="xingming" column="xingming"/>
        <result property="chepaihao" column="chepaihao"/>
        <result property="cheliangpinpai" column="cheliangpinpai"/>
        <result property="kaishishijian" column="kaishishijian"/>
        <result property="jieshushijian" column="jieshushijian"/>
        <result property="sudu" column="sudu"/>
        <result property="tupian" column="tupian"/>
        <result property="userid" column="userid"/>
        <result property="longitude" column="longitude"/>
        <result property="latitude" column="latitude"/>
        <result property="fulladdress" column="fulladdress"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.YunshuxinxiVO" >
		SELECT * FROM yunshuxinxi  yunshuxinxi         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.YunshuxinxiVO" >
		SELECT  yunshuxinxi.* FROM yunshuxinxi  yunshuxinxi
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.YunshuxinxiView" >

		SELECT  yunshuxinxi.* FROM yunshuxinxi  yunshuxinxi 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.YunshuxinxiView" >
		SELECT * FROM yunshuxinxi  yunshuxinxi <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, sum(${params.yColumn}) total FROM yunshuxinxi
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM yunshuxinxi
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM yunshuxinxi
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM yunshuxinxi
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>
   
    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM yunshuxinxi  
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>



	
</mapper>
